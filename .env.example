# ─────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─────────────────────────────────────────────────
# DATABASE  (Neon / Supabase / local Postgres)
# ─────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/camply?schema=public"

# ─────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_access_key_here_change_me
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────
# REDIS  (Upstash / local Redis)
# ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────
# CLOUDINARY  (image uploads)
# ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8080,https://camply.live,https://camply-frontend.vercel.app
